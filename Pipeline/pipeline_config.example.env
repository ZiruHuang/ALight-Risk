# Example configuration for main_kappa.sh and main_lambda.sh
# Copy this file to a local, untracked file (for example, pipeline_config.env),
# edit the paths, and load it before running a pipeline:
#   set -a
#   source pipeline_config.env
#   set +a
#   ./main_kappa.sh

# Repository root. If omitted, the directory containing the shell script is used.
PROJECT_ROOT=/path/to/ALight-Risk

# Required IgBLAST V-germline database prefix.
IGBLAST_GERMLINE_DB=/path/to/IgBLAST/Protein/human_germline_IGLV_IGKV

# Required path to iFeature.py (used by Step3_iFeature.py for descriptor extraction).
IFEATURE_SCRIPT=/path/to/iFeature/iFeature.py

# Executables. Command names are sufficient when they are available in PATH.
PYTHON_BIN=python3
RSCRIPT_BIN=Rscript
PERL_BIN=perl
CDHIT_BIN=cd-hit
IGBLASTP_BIN=igblastp
CONDA_BIN=conda

# Conda environment containing MRMD3.0.
MRMD_CONDA_ENV=MRMD3

# Repeated-resampling settings.
START_ROUND=1
END_ROUND=30
THREADS=8
BASELINE_THREADS=12

# CD-HIT identity threshold used for non-AL sequences, consistent with the manuscript.
CDHIT_IDENTITY=0.90

# Set to 0 to remove temporary work directories after the last round.
KEEP_FINAL_WORKDIR=1
